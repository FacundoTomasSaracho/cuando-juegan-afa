# Copiar este archivo a .env y completar con tus credenciales de Twitter
# Mientras no estén configuradas, el servicio corre en modo DRY RUN (solo logs)
# Solo se necesitan estos 4 campos (OAuth 1.0a) para publicar tweets.

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
